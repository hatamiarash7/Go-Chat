# Start mode: 'server' or 'client'
START_MODE=server

# Server/Client connection settings
HOST=localhost
PORT=12345

# Encryption mode: 'pgp' or 'aes'
# - pgp: Uses GPG/PGP public-key encryption (requires key files)
# - aes: Uses AES-256-GCM symmetric encryption (requires shared passphrase)
ENCRYPTION=pgp

# PGP-specific settings (required when ENCRYPTION=pgp)
PUBLIC_KEY_FILE=./keys/public.asc
PRIVATE_KEY_FILE=./keys/private.asc

# Passphrase for PGP private key or AES shared secret
PASSPHRASE=your-secure-passphrase